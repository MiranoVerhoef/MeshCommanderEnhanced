<Window
    x:Class="MeshCommander.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="Root">
        <StackPanel x:Name="StatusPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <ProgressRing x:Name="Progress" IsActive="True" Width="36" Height="36" />
            <TextBlock x:Name="StatusText" Text="Starting MeshCommander Enhanced…" FontSize="16" TextAlignment="Center" />
            <TextBlock x:Name="ErrorText" MaxWidth="640" TextWrapping="Wrap" TextAlignment="Center" Visibility="Collapsed" />
            <Button x:Name="OpenLogButton" Content="Open diagnostic log" HorizontalAlignment="Center" Visibility="Collapsed" Click="OpenLogButton_Click" />
        </StackPanel>
    </Grid>
</Window>
