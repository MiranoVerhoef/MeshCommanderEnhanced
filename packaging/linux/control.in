Package: meshcommander-enhanced
Version: @VERSION@
Section: net
Priority: optional
Architecture: amd64
Maintainer: MiranoVerhoef
Depends: libgtk-3-0, libnotify4, libwebkit2gtk-4.1-0 | libwebkit2gtk-4.0-37
